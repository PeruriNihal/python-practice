even_numbers=0
odd_numbers=0

number = int(input("Enter a number or enter -1 to exit: "))

while number!= -1:

    if number%2 == 1:
        odd_numbers+=1
    else:
        even_numbers+=1

    number = int(input("Enter a number or enter -1 to exit: "))

print("Number of even numbers:", even_numbers)
print("Number of odd numbers:", odd_numbers)